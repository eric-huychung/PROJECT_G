# Vercel AI Gateway — server-only (never expose to the client)
AI_GATEWAY_API_KEY=

# Active model (server-only). Uncomment ONE — see lib/insights/gateway_model.ts
AI_GATEWAY_MODEL_ID=google/gemini-2.5-flash-lite

# --- Top 5 for insight pipeline testing (plan / query / narrate) ---
# 1. google/gemini-2.5-flash-lite   $0.10 / $0.40 per 1M — best SQL+JSON baseline (Goldie default)
# 2. openai/gpt-5-nano              $0.05 / $0.40 per 1M — cheap input, strong JSON
# 3. amazon/nova-lite               $0.06 / $0.24 per 1M — cheap output, fast (text-only CSV is fine)
# 4. google/gemini-2.0-flash-lite   $0.075 / $0.30 per 1M — older Gemini, lower cost
# 5. meta/llama-3.1-8b              ~$0.03 / ~$0.05 per 1M — cheapest; weaker JSON (needs fallbacks)
#
# Text-only alternative to nova-lite: amazon/nova-micro ($0.035 / $0.14 per 1M)
